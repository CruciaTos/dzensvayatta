# Google OAuth (Gmail + Calendar)
# 1. Create a Google Cloud project
# 2. Enable Gmail API + Google Calendar API
# 3. Create OAuth client credentials (Web application)
# 4. Add redirect URI: http://localhost:3000/oauth2callback
# 5. Run: node scripts/get-google-refresh-token.mjs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Calendar + notifications
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_SENDER_EMAIL=dzen.ai.platform@gmail.com
DZEN_NOTIFICATION_EMAIL=dzen.ai.platform@gmail.com
